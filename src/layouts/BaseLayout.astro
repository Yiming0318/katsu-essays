---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Markets, AI, and risk.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/katsu-essays/favicon.svg" />
    <title>{title} · Katsu Essays</title>
    <style is:global>
      :root {
        --background: #ffffff;
        --text: #111111;
        --muted-text: #6e6e73;
        --border: #e5e5e7;
        --card-background: #ffffff;
        --accent: #0071e3;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--background);
        color: var(--text);
        line-height: 1.7;
      }
      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      .container { max-width: 1080px; margin: 0 auto; padding: 0 1.25rem; }
      .reading-width { max-width: 760px; margin: 0 auto; }

      header { border-bottom: 1px solid var(--border); background: rgba(255, 255, 255, 0.92); backdrop-filter: saturate(180%) blur(20px); position: sticky; top: 0; z-index: 10; }
      nav { display: flex; justify-content: space-between; align-items: center; min-height: 56px; gap: 1rem; }
      .brand { font-size: 1rem; font-weight: 600; letter-spacing: -0.01em; }
      .tag { font-size: 0.82rem; color: var(--muted-text); margin-top: 0.1rem; }
      .menu { display: flex; gap: 1.15rem; font-size: 0.92rem; color: var(--muted-text); }
      .menu a:hover { color: var(--text); }

      main { padding: 4.6rem 0 5rem; }
      h1, h2, h3 { margin: 0; line-height: 1.1; letter-spacing: -0.025em; }
      h2 { font-size: clamp(1.6rem, 2vw, 2rem); margin-bottom: 1rem; }
      p { font-size: 1.05rem; margin: 0 0 1rem; }
      .grid { display: grid; gap: 1.2rem; }
      .card { border: 1px solid var(--border); border-radius: 14px; background: var(--card-background); }

      article :global(p) { line-height: 1.9; color: #1d1d1f; }
      article :global(blockquote) { margin: 2rem 0; padding: 1rem 1.15rem; border-left: 3px solid #d2d2d7; color: #3a3a3c; background: #fafafc; border-radius: 0 10px 10px 0; }
      article :global(img) { border-radius: 12px; border: 1px solid var(--border); margin: 1.8rem auto 0.4rem; }
      article :global(img + em), article :global(img + i) { display: block; text-align: center; color: var(--muted-text); font-size: 0.9rem; margin-bottom: 1.2rem; }

      footer { border-top: 1px solid var(--border); padding: 2rem 0; color: var(--muted-text); font-size: 0.92rem; }
      @media (max-width: 760px) {
        nav { flex-direction: column; align-items: flex-start; padding: 0.75rem 0; }
        .menu { flex-wrap: wrap; gap: 0.85rem; }
        main { padding-top: 3.2rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div>
            <a class="brand" href="/katsu-essays/">Katsu Essays</a>
            <div class="tag">Markets, AI, and risk.</div>
          </div>
          <div class="menu">
            <a href="/katsu-essays/">Home</a>
            <a href="/katsu-essays/essays">Essays</a>
            <a href="/katsu-essays/about">About</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">© {new Date().getFullYear()} Katsu Essays.</div>
    </footer>
  </body>
</html>
