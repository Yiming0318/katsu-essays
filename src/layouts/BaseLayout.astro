---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Markets, AI infrastructure, and the psychology of risk.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/katsu-essays/favicon.svg" />
    <title>{title} · Katsu Essays</title>
    <style is:global>
      :root {
        --background: #f8f8f6;
        --text: #1d1d1b;
        --muted-text: #66625b;
        --border: #e5e2dc;
        --card-background: #fdfdfc;
        --accent: #2f3a42;
      }

      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Charter, 'Iowan Old Style', 'Palatino Linotype', 'Times New Roman', serif;
        background: var(--background);
        color: var(--text);
        line-height: 1.75;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }

      .container { max-width: 1120px; margin: 0 auto; padding: 0 1.2rem; }
      .reading-width { max-width: 740px; margin: 0 auto; }

      header {
        border-bottom: 1px solid var(--border);
        background: color-mix(in srgb, var(--background) 92%, white);
        backdrop-filter: blur(8px);
        position: sticky;
        top: 0;
        z-index: 10;
      }

      nav { display: flex; justify-content: space-between; align-items: center; gap: 1rem; min-height: 68px; }
      .brand { font-size: 1rem; letter-spacing: 0.11em; text-transform: uppercase; font-weight: 700; }
      .tag { font-size: 0.86rem; color: var(--muted-text); margin-top: 0.15rem; }
      .menu { display: flex; gap: 1.2rem; font-size: 0.95rem; color: var(--muted-text); }
      .menu a:hover { color: var(--text); }

      main { padding: 4.4rem 0 5rem; }
      h1, h2, h3 { line-height: 1.14; letter-spacing: -0.02em; margin: 0; }
      h2 { font-size: clamp(1.6rem, 2.2vw, 2rem); margin-bottom: 1rem; }
      p { font-size: 1.08rem; margin: 0 0 1.1rem; }

      .grid { display: grid; gap: 1.4rem; }
      .card {
        border: 1px solid var(--border);
        border-radius: 18px;
        background: var(--card-background);
      }

      article :global(p) { line-height: 1.9; color: #2c2924; }
      article :global(h2) { margin: 2.4rem 0 0.7rem; }
      article :global(h3) { margin: 2rem 0 0.5rem; }
      article :global(blockquote) {
        margin: 2rem 0;
        padding: 1.2rem 1.4rem;
        border-left: 2px solid #9e988c;
        border-radius: 0 14px 14px 0;
        background: #f4f2ee;
        color: #3f3a34;
        font-style: italic;
      }
      article :global(img) {
        border-radius: 14px;
        margin: 1.9rem auto 0.4rem;
        border: 1px solid var(--border);
      }
      article :global(img + em), article :global(img + i) {
        display: block;
        margin: 0 auto 1.4rem;
        text-align: center;
        color: var(--muted-text);
        font-size: 0.95rem;
      }

      footer { border-top: 1px solid var(--border); padding: 2rem 0; color: var(--muted-text); font-size: 0.95rem; }

      @media (max-width: 760px) {
        nav { align-items: flex-start; flex-direction: column; padding: 0.9rem 0; }
        .menu { gap: 0.9rem; flex-wrap: wrap; }
        main { padding-top: 3rem; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div>
            <a class="brand" href="/katsu-essays/">Katsu Essays</a>
            <div class="tag">Markets, AI infrastructure, and the psychology of risk.</div>
          </div>
          <div class="menu">
            <a href="/katsu-essays/">Home</a>
            <a href="/katsu-essays/essays">Essays</a>
            <a href="/katsu-essays/about">About</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">© {new Date().getFullYear()} Katsu Essays.</div>
    </footer>
  </body>
</html>
