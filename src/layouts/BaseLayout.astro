---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
interface Props { title: string; description?: string; }
const { title, description = 'A personal archive of essays about investing, AI cycles, money, bubbles, and the strange ways humans make decisions under uncertainty.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/katsu-essays/favicon.svg" />
    <title>{title} · Katsu Essays</title>
    <style is:global>
      :root { --background:#f8f6f1; --text:#1f1d1b; --muted-text:#6c665f; --border:#dcd6cd; --card-background:#fdfcf8; --accent:#8b6c4f; }
      *{box-sizing:border-box} body{margin:0;font-family: ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif;background:var(--background);color:var(--text);line-height:1.65}
      a{text-decoration:none;color:inherit} img{max-width:100%;display:block}
      .site-container{max-width:1120px;margin:0 auto;padding:0 1.25rem}.site-container.narrow{max-width:720px}
      .section{margin-top:3.2rem}.section:first-child{margin-top:0}
      .card{border:1px solid var(--border);border-radius:14px;background:var(--card-background)} .grid{display:grid;gap:1.2rem}
      .site-header{border-bottom:1px solid var(--border);background:color-mix(in srgb,var(--background) 94%,#fff 6%)} .accent-line{height:2px;background:color-mix(in srgb,var(--accent) 38%, transparent)}
      nav{display:flex;justify-content:space-between;align-items:center;min-height:76px;gap:1rem}.brand-wrap{display:flex;flex-direction:column}.brand{font-size:1.18rem;font-weight:600}.tag{font-size:.82rem;color:var(--muted-text)}
      .menu{display:flex;gap:1.2rem}.menu-link{font-size:.93rem;color:var(--muted-text);padding-bottom:.15rem;border-bottom:1px solid transparent}.menu-link.active{color:var(--text);border-bottom-color:var(--accent)}
      main{padding:3.1rem 0 4.2rem}h1,h2,h3{margin:0;letter-spacing:-.01em;line-height:1.15}p{margin:0 0 1rem}
      footer{border-top:1px solid var(--border);padding:1.8rem 0}.footer-inner{color:var(--muted-text);font-size:.9rem}
      @media (max-width: 780px){nav{flex-direction:column;align-items:flex-start;padding:.8rem 0}.menu{gap:.9rem;flex-wrap:wrap}main{padding-top:2.2rem}}
    </style>
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
  </body>
</html>
