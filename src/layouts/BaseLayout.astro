---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Markets, AI infrastructure, and the psychology of risk.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/katsu-essays/favicon.svg" />
    <title>{title} · Katsu Essays</title>
    <style is:global>
      :root {--bg:#fcfcfb;--text:#1e1e1e;--muted:#666;--border:#e9e7e4;--accent:#0f172a;}
      *{box-sizing:border-box} body{margin:0;font-family: Charter, 'Iowan Old Style', 'Palatino Linotype', 'Times New Roman', serif;background:var(--bg);color:var(--text);line-height:1.7}
      a{color:inherit;text-decoration:none}
      .container{max-width:1040px;margin:0 auto;padding:0 1.2rem}
      header{border-bottom:1px solid var(--border);background:rgba(252,252,251,.93);backdrop-filter: blur(4px);position:sticky;top:0;z-index:5}
      nav{display:flex;justify-content:space-between;align-items:center;padding:1rem 0}
      .brand{font-size:1.05rem;letter-spacing:.06em;text-transform:uppercase;font-weight:700}
      .tag{font-size:.9rem;color:var(--muted)}
      .menu{display:flex;gap:1rem;font-size:.95rem}
      main{padding:3rem 0 4rem}
      h1,h2,h3{line-height:1.2;letter-spacing:-0.01em}
      p{font-size:1.05rem}
      .grid{display:grid;gap:1.4rem}
      .card{border:1px solid var(--border);border-radius:16px;padding:1rem;background:white}
      .card img{width:100%;height:210px;object-fit:cover;border-radius:12px;margin-bottom:1rem}
      blockquote{margin:1.8rem 0;padding:1rem 1.2rem;border-left:3px solid #a8a29e;background:#fafaf9;font-style:italic;color:#444}
      footer{border-top:1px solid var(--border);padding:2rem 0;color:var(--muted);font-size:.95rem}
      @media (min-width: 760px){.hero h1{font-size:3.4rem}.latest{grid-template-columns:repeat(2,1fr)}}
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <div>
            <a class="brand" href="/katsu-essays/">Katsu Essays</a>
            <div class="tag">Markets, AI infrastructure, and the psychology of risk.</div>
          </div>
          <div class="menu">
            <a href="/katsu-essays/essays">Essays</a>
            <a href="/katsu-essays/topics">Topics</a>
            <a href="/katsu-essays/about">About</a>
          </div>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer>
      <div class="container">© {new Date().getFullYear()} Katsu Essays.</div>
    </footer>
  </body>
</html>
