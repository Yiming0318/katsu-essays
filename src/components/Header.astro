---
import { withBase } from '../utils/paths';
const pathname = Astro.url.pathname;
const links = [
  { href: withBase('/'), label: 'Home' },
  { href: withBase('/essays'), label: 'Essays' },
  { href: withBase('/topics'), label: 'Categories' },
  { href: withBase('/about'), label: 'About' }
];

const home = withBase('/');
const isActive = (href: string) => (href === home ? pathname === href : pathname.startsWith(href));
---

<header class="site-header">
  <div class="accent-line"></div>
  <div class="site-container">
    <nav>
      <a class="brand-wrap" href={withBase("/")}>
        <span class="brand">Katsu Essays</span>
        <span class="tag">Personal Essay Archive</span>
      </a>
      <div class="menu">
        {links.map((link) => (
          <a href={link.href} class:list={["menu-link", { active: isActive(link.href) }]}>{link.label}</a>
        ))}
      </div>
    </nav>
  </div>
</header>
