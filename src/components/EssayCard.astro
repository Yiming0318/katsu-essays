---
interface Props {
  href: string;
  title: string;
  subtitle: string;
  date: Date;
  category: string;
  image: string;
  alt: string;
  readingTime: string;
  featured?: boolean;
}

const { href, title, subtitle, date, category, image, alt, readingTime, featured = false } = Astro.props;
---

<article class:list={["essay-card", "card", { featured }]}>
  <a href={href}>
    <img src={image} alt={alt} loading="lazy" />
    <div class="content">
      <div class="category">{category}</div>
      <h3>{title}</h3>
      <p>{subtitle}</p>
      <div class="meta">{date.toLocaleDateString('en-US', {year: 'numeric', month: 'long', day: 'numeric'})} · {readingTime}</div>
    </div>
  </a>
</article>

<style>
  .essay-card { overflow: hidden; }
  .essay-card a { display: block; }
  .essay-card img { width: 100%; height: 230px; object-fit: cover; border-bottom: 1px solid var(--border); }
  .essay-card .content { padding: 1.1rem 1.2rem 1.2rem; }
  .category { font-size: 0.74rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted-text); margin-bottom: 0.5rem; }
  h3 { margin: 0 0 0.45rem; font-size: clamp(1.45rem, 2vw, 1.75rem); }
  p { margin: 0 0 0.8rem; color: #4f4a43; font-size: 1.02rem; }
  .meta { font-size: 0.9rem; color: var(--muted-text); }

  .featured { border-color: color-mix(in srgb, var(--accent) 20%, var(--border)); box-shadow: 0 12px 30px rgba(15, 23, 32, 0.08); }
  .featured img { height: 340px; }
  .featured h3 { font-size: clamp(1.9rem, 3vw, 2.5rem); }
  .featured p { font-size: 1.12rem; }

  @media (max-width: 760px) {
    .essay-card img { height: 210px; }
    .featured img { height: 250px; }
  }
</style>
