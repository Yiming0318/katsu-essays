---
import { assetPath } from '../utils/paths';

interface Props { href:string; title:string; subtitle:string; excerpt?:string; date:Date; category:string; image:string; alt:string; readingTime:string; featured?:boolean; }
const { href, title, subtitle, excerpt, date, category, image, alt, readingTime, featured = false } = Astro.props;
---
<article class:list={["essay-card", "card", { featured }]}>
  <a href={href}>
    <img src={assetPath(image)} alt={alt} loading="lazy" />
    <div class="content">
      <div class="category">{category}</div>
      <h3>{title}</h3>
      <p class="subtitle">{subtitle}</p>
      {excerpt && <p class="excerpt">{excerpt}</p>}
      <div class="meta">{date.toLocaleDateString('en-US', {year:'numeric', month:'long', day:'numeric'})} · {readingTime}</div>
    </div>
  </a>
</article>
<style>
.essay-card{overflow:hidden;transition:transform .2s ease,border-color .2s ease}.essay-card:hover{transform:translateY(-2px);border-color:color-mix(in srgb,var(--accent) 32%,var(--border))}
.essay-card a{display:block}.essay-card img{width:100%;aspect-ratio:16/10;object-fit:cover;border-bottom:1px solid var(--border);background:var(--card-background)}.content{padding:1.1rem}
.category{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted-text);margin-bottom:.5rem}.subtitle{color:#4c463f;margin-bottom:.5rem}.excerpt{font-style:italic;color:#564f47}
h3{font-size:1.28rem;margin-bottom:.45rem}.meta{font-size:.87rem;color:var(--muted-text)}
.featured a{display:grid;grid-template-columns:1.05fr 1fr;min-height:340px}.featured img{height:100%;aspect-ratio:auto;border-right:1px solid var(--border);border-bottom:0}.featured .content{padding:1.8rem}.featured h3{font-size:2rem}
@media (max-width: 860px){.featured a{grid-template-columns:1fr;min-height:auto}.featured img{border-right:0;border-bottom:1px solid var(--border);min-height:220px}}
</style>
