---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryCard from '../components/CategoryCard.astro';
import Container from '../components/Container.astro';
import { getCollection } from 'astro:content';
const essays=await getCollection('essays');
const categories=[
{name:'Markets & Investing',description:'Notes on bubbles, leverage, timing, and retail investor psychology.'},
{name:'AI & Technology Cycles',description:'Essays on AI tools, model economics, hype cycles, and who ultimately pays the bill.'},
{name:'Money & Human Nature',description:'Stories about wealth, incentives, patience, compounding, and how people think about money.'}
];
---
<BaseLayout title="Categories"><Container><section class="section"><h1>Categories</h1><p class="sub">Explore themes across the archive.</p><div class="grid list">{categories.map((category)=><CategoryCard name={category.name} description={category.description} count={essays.filter((essay)=>essay.data.category===category.name).length} />)}</div></section></Container></BaseLayout>
<style>.sub{color:var(--muted-text)}.list{margin-top:1.1rem;gap:1rem}.category-card{padding:1.45rem 1.5rem;display:flex;justify-content:space-between;align-items:flex-end;gap:1rem;transition:border-color .2s ease,transform .2s ease,box-shadow .2s ease}.category-card:hover{border-color:color-mix(in srgb,var(--accent) 28%,var(--border));transform:translateY(-2px);box-shadow:0 6px 18px color-mix(in srgb,var(--accent) 7%,transparent)}.category-card h3{margin-bottom:.58rem;font-size:1.2rem}.category-card p{margin:0 0 .7rem;color:#4f4a44;max-width:66ch}.category-card small{color:var(--muted-text);font-size:.88rem}.cta{color:#5c554d;font-size:.9rem;letter-spacing:.01em}</style>
