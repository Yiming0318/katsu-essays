---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayCard from '../components/EssayCard.astro';
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays')).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featured = essays.find((essay) => essay.data.featured) ?? essays[0];
const latest = essays.filter((essay) => essay.slug !== featured.slug).slice(0, 3);
const categories = [
  {
    name: 'Markets & Investing',
    description: 'Notes on bubbles, leverage, timing, and retail investor psychology.'
  },
  {
    name: 'AI & Technology Cycles',
    description: 'Essays on AI tools, model economics, hype cycles, and who ultimately pays the bill.'
  },
  {
    name: 'Money & Human Nature',
    description: 'Stories about wealth, incentives, patience, compounding, and how people think about money.'
  }
];
---

<BaseLayout title="Home">
  <section class="hero">
    <p class="eyebrow">Personal Essay Archive</p>
    <h1>Essays on Markets, AI, and the Psychology of Risk</h1>
    <p class="lede">A personal archive of essays about investing, AI cycles, money, bubbles, and the strange ways humans make decisions under uncertainty.</p>
  </section>

  <section class="section-gap">
    <h2>Featured</h2>
    <EssayCard
      featured
      href={`/katsu-essays/essays/${featured.slug}/`}
      title={featured.data.title}
      subtitle={featured.data.subtitle}
      date={featured.data.pubDate}
      category={featured.data.category}
      image={featured.data.coverImage}
      alt={featured.data.coverAlt}
      readingTime={featured.data.readingTime}
    />
  </section>

  <section class="section-gap">
    <h2>Latest</h2>
    <div class="grid latest-grid">
      {latest.map((essay) => (
        <EssayCard
          href={`/katsu-essays/essays/${essay.slug}/`}
          title={essay.data.title}
          subtitle={essay.data.subtitle}
          date={essay.data.pubDate}
          category={essay.data.category}
          image={essay.data.coverImage}
          alt={essay.data.coverAlt}
          readingTime={essay.data.readingTime}
        />
      ))}
    </div>
  </section>

  <section>
    <h2>Categories</h2>
    <div class="grid topic-grid">
      {categories.map((category) => (
        <div class="card topic-card">
          <h3>{category.name}</h3>
          <p>{category.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero { margin-bottom: 5rem; padding-top: 0.6rem; }
  .eyebrow { text-transform: uppercase; letter-spacing: 0.11em; color: var(--muted-text); font-size: 0.82rem; margin-bottom: 0.9rem; }
  h1 { max-width: 12ch; font-size: clamp(2.8rem, 7vw, 5.3rem); margin-bottom: 1.2rem; }
  .lede { max-width: 56ch; color: #47423c; font-size: 1.15rem; }
  .section-gap { margin-bottom: 3.2rem; }
  .latest-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .topic-grid { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
  .topic-card { padding: 1.4rem; color: #47423c; }
  .topic-card h3 { font-size: 1.05rem; margin-bottom: 0.45rem; }
  .topic-card p { margin: 0; color: var(--muted-text); font-size: 0.95rem; line-height: 1.6; }

  @media (max-width: 980px) { .latest-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 760px) {
    .hero { margin-bottom: 3rem; }
    h1 { max-width: 100%; }
    .latest-grid { grid-template-columns: 1fr; }
  }
</style>
