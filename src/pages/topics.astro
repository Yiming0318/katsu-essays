---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Categories">
  <h1>Categories</h1>
  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-top:1.2rem">
    <section class="card"><h2>Markets & Investing</h2><p>Notes on bubbles, leverage, timing, and retail investor psychology.</p></section>
    <section class="card"><h2>AI & Technology Cycles</h2><p>Essays on AI tools, model economics, hype cycles, and who ultimately pays the bill.</p></section>
    <section class="card"><h2>Money & Human Nature</h2><p>Stories about wealth, incentives, patience, compounding, and how people think about money.</p></section>
  </div>
</BaseLayout>
