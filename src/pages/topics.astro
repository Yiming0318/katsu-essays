---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Topics">
  <h1>Topics</h1>
  <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));margin-top:1.2rem">
    <section class="card"><h2>Markets</h2><p>Decision frameworks, cycle psychology, and execution discipline.</p></section>
    <section class="card"><h2>AI & Infrastructure</h2><p>Compute economics, model deployment, and infrastructure incentives.</p></section>
    <section class="card"><h2>Money Philosophy</h2><p>Compounding behavior, life design, and value systems around money.</p></section>
  </div>
</BaseLayout>
